# PostgreSQL
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/fluentia_db
SPRING_DATASOURCE_USERNAME=rodrigo
SPRING_DATASOURCE_PASSWORD=

# Public URLs (used in verification email links and redirects)
APP_PUBLIC_URL=http://localhost:5173
APP_PUBLIC_API_BASE_URL=http://localhost:8080/api

# Sign in with Google — Web application OAuth 2.0 Client ID from Google Cloud Console.
# Use either name (app reads both). Many Google samples use GOOGLE_CLIENT_ID.
# GOOGLE_WEB_CLIENT_ID=
# GOOGLE_CLIENT_ID=

# Gmail API — send verification email (OAuth client + refresh token with gmail.send scope).
# Often the same OAuth client as above, or a separate "Desktop" client used once to obtain the refresh token.
# Use Google OAuth Playground or a small script to authorize and copy the refresh token.
GMAIL_OAUTH_CLIENT_ID=
GMAIL_OAUTH_CLIENT_SECRET=
GMAIL_OAUTH_REFRESH_TOKEN=
GMAIL_FROM_EMAIL=

# Shorthand aliases (optional — used if the GMAIL_* vars above are empty)
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# Local dev without Gmail: create verified users immediately (no email sent)
SKIP_EMAIL_VERIFICATION=false
