# Fluentia Frontend – copy to .env and adjust if needed.
# Do not commit .env to version control.

# API base URL (optional).
# - Leave unset in development: Vite proxies /api to the backend (see vite.config.ts).
# - Set in production or when backend runs elsewhere, e.g.:
#   VITE_API_URL=http://localhost:8080/api
#   VITE_API_URL=https://your-backend.com/api

# VITE_API_URL=

# Same Web Client ID as backend GOOGLE_WEB_CLIENT_ID (optional fallback so the Google button loads without /api).
# VITE_GOOGLE_CLIENT_ID=
